<?xml version="1.0" encoding="utf-8"?>
<!--
    USB device filter for known RNode-compatible hardware.
    Android delivers ACTION_USB_DEVICE_ATTACHED to the app when any of these
    devices is plugged in.

    VID/PID pairs:
      CP2102 (Silicon Labs)  — 0x10C4 / 0xEA60  (most common RNode)
      CH340 (WCH)            — 0x1A86 / 0x7523
      FTDI FT232R            — 0x0403 / 0x6001
      ESP32-S3 native USB    — 0x303A / 0x1001  (newer RNode hardware)
      RAK4630 / nRF52840     — 0x239A / 0x8029  (Adafruit BSP, RNode 1.85)
-->
<resources>
    <!-- Silicon Labs CP2102 / CP2104 (most RNodes) -->
    <usb-device vendor-id="4292" product-id="60032" />  <!-- 0x10C4 / 0xEA60 -->

    <!-- WCH CH340 / CH341 -->
    <usb-device vendor-id="6790" product-id="29987" />  <!-- 0x1A86 / 0x7523 -->

    <!-- FTDI FT232R -->
    <usb-device vendor-id="1027" product-id="24577" />  <!-- 0x0403 / 0x6001 -->

    <!-- Espressif ESP32-S3 native USB (newer RNode builds) -->
    <usb-device vendor-id="12346" product-id="4097" />  <!-- 0x303A / 0x1001 -->

    <!-- RAK4630 / nRF52840 (Adafruit BSP, RNode 1.85) -->
    <usb-device vendor-id="9114" product-id="32809" />   <!-- 0x239A / 0x8029 -->
</resources>
